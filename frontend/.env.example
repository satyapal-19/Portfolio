# Point the contact form at your Railway API (public URL, no trailing slash).
# In Vercel: Project → Settings → Environment Variables → VITE_API_URL
# Example: https://portfolio-production-xxxx.up.railway.app
# VITE_API_URL=

# Local dev: leave unset — `npm run dev` proxies /api → http://localhost:5000 (vite.config.js).
