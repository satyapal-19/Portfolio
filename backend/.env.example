# Server (Railway sets PORT automatically — optional locally)
PORT=5000

MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/portfolio

# Gmail (App Password)
EMAIL_USER=your.address@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="Satyapal Portfolio <your.address@gmail.com>"
CONTACT_MAIL_TO=your.address@gmail.com

# Optional
BRAND_NAME=Satyapal Gaikwad
PORTFOLIO_URL=https://satyapalgaikwad.vercel.app

# CORS: comma-separated extra origins (Vercel production + previews if needed)
# Example: https://satyapalgaikwad.vercel.app,https://my-app-git-main-user.vercel.app
ALLOWED_ORIGINS=

# Set to true to allow any https://*.vercel.app origin (preview deployments)
CORS_ALLOW_VERCEL_PREVIEWS=false

# Legacy — also merged into CORS allow list if set
CLIENT_URL=http://localhost:5173
